# Israel Grocery MCP — environment variables
# Copy to .env and fill in as needed.

# --- App-wide ---
ISRAELGROCERY_STATE_DIR=.local/state
ISRAELGROCERY_DEBUG_DIR=.local/debug
ISRAELGROCERY_BROWSER_DIR=.local/browser
ISRAELGROCERY_MAX_SEARCH_RESULTS=8

# --- Shufersal ---
SHUFERSAL_BASE_URL=https://www.shufersal.co.il
SHUFERSAL_STOREFRONT_PREFIX=/online/he
SHUFERSAL_REQUEST_TIMEOUT_SECONDS=20
SHUFERSAL_LOGIN_TIMEOUT_SECONDS=600
SHUFERSAL_BROWSER_CHANNEL=chrome    # set to empty to auto-detect Chromium
SHUFERSAL_DEBUG_HTTP=false

# --- Tiv Taam ---
TIVTAAM_BASE_URL=https://www.tivtaam.co.il
TIVTAAM_RETAILER_ID=1062
TIVTAAM_BRANCH_ID=943               # 943 = default branch
TIVTAAM_REQUEST_TIMEOUT_SECONDS=20
TIVTAAM_DEBUG_HTTP=false

# Auto-login credentials (optional — fill in to log in automatically on startup)
# TIVTAAM_EMAIL=your@email.com
# TIVTAAM_PASSWORD=yourpassword

# --- Rami Levy ---
# Rami Levy uses email + SMS OTP (no password). The login_ramilevi tool only needs your email.
# RAMILEVI_EMAIL=your@email.com
# RAMILEVI_STORE_ID=331              # store for product search (default: 331)
# RAMILEVI_CART_STORE_ID=412         # delivery store for cart (default: 412)
